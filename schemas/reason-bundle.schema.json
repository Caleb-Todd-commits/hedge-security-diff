              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "includedFiles": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "includedBytes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "omitted": {
              "type": "object",
              "properties": {
                "fileLimit": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "byteLimit": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "unsafeOrUnreadable": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "binary": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": ["fileLimit", "byteLimit", "unsafeOrUnreadable", "binary"],
              "additionalProperties": false
            },
            "diagnostics": {
              "default": [],
              "type": "array",

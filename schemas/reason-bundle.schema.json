      "type": "string",
      "const": "0.1"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "pullRequest": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "baseSha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40,64}$"
    },
    "headSha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40,64}$"
    },
    "workflowRef": {
      "type": "string",
      "minLength": 1
    },
    "actionVersion": {
      "type": "string",
      "minLength": 1
    },
    "collectionManifestDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "analysis": {

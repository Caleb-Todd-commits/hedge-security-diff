{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string"
    },
    "surfaceChanged": {
      "type": "boolean"
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "node-added",
              "node-removed",
              "node-changed",
              "edge-added",
              "edge-removed",
              "edge-changed",
              "invariant-evaluated"
            ]
          },
          "summary": {
            "type": "string"
          },
          "subjectIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string"
                },
                "line": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "endLine": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "snippet": {
                  "type": "string"
                },
                "extractor": {
                  "type": "string"
                },
                "commit": {
                  "type": "string"
                }
              },
              "required": ["file", "extractor"],
              "additionalProperties": false
            }
          },
          "source": {
            "default": "deterministic",
            "type": "string",
            "const": "deterministic"
          },
          "metadata": {
            "default": {},
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": ["id", "kind", "summary", "subjectIds", "evidence", "source", "metadata"],
        "additionalProperties": false
      }
    },
    "inferences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "hypothesis": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "observationIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assumptions": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "riskFingerprint": {
            "type": "string"
          },
          "origin": {
            "type": "string",
            "enum": ["deterministic", "policy", "invariant", "model", "unknown"]
          },
          "model": {
            "type": "string"
          }
        },
        "required": ["id", "hypothesis", "confidence", "observationIds", "assumptions", "origin"],
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["allow", "warn", "block", "accept", "verify"]
          },
          "reason": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": ["threshold", "invariant", "policy", "human", "lifecycle"]
          },
          "riskFingerprints": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invariantIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "observationIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inferenceIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "type",
          "reason",
          "source",
          "riskFingerprints",
          "invariantIds",
          "observationIds",
          "inferenceIds"
        ],
        "additionalProperties": false
      }
    },
    "invariantEvaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "invariantId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "status": {
            "type": "string",
            "enum": ["satisfied", "violated", "not-applicable", "unknown"]
          },
          "matchedNodeIds": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingControls": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "authentication",
                "authorization",
                "validation",
                "rate-limit",
                "size-limit",
                "content-type",
                "encryption",
                "logging",
                "ownership",
                "other"
              ]
            }
          },
          "evidence": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string"
                },
                "line": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "endLine": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "snippet": {
                  "type": "string"
                },
                "extractor": {
                  "type": "string"
                },
                "commit": {
                  "type": "string"
                }
              },
              "required": ["file", "extractor"],
              "additionalProperties": false
            }
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "invariantId",
          "description",
          "severity",
          "status",
          "matchedNodeIds",
          "missingControls",
          "evidence",
          "reason"
        ],
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "origin": {
            "default": "unknown",
            "type": "string",
            "enum": ["deterministic", "policy", "invariant", "model", "unknown"]
          },
          "status": {
            "default": "open",
            "type": "string",
            "enum": [
              "open",
              "mitigation-detected",
              "verification-available",
              "verified",
              "accepted",
              "closed"
            ]
          },
          "stride": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Spoofing",
                "Tampering",
                "Repudiation",
                "Information Disclosure",
                "Denial of Service",
                "Elevation of Privilege"
              ]
            }
          },
          "cwe": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "asset": {
            "type": "string"
          },
          "attackerCapability": {
            "type": "string"
          },
          "entryPoint": {
            "type": "string"
          },
          "trustBoundary": {
            "type": "string"
          },
          "precondition": {
            "type": "string"
          },
          "attackPath": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "potentialImpact": {
            "type": "string"
          },
          "existingControls": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingControls": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "securityInvariant": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string"
                },
                "line": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "endLine": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "snippet": {
                  "type": "string"
                },
                "extractor": {
                  "type": "string"
                },
                "commit": {
                  "type": "string"
                }
              },
              "required": ["file", "extractor"],
              "additionalProperties": false
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "suggestedTest": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "framework": {
                "default": "vitest",
                "type": "string"
              },
              "language": {
                "default": "typescript",
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              }
            },
            "required": ["title", "framework", "language", "code", "purpose"],
            "additionalProperties": false
          },
          "remediationPrompt": {
            "type": "string"
          },
          "verificationHistory": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "recordedAt": {
                  "default": "2026-07-15T03:10:35.089Z",
                  "type": "string"
                },
                "recordedBy": {
                  "default": "unknown",
                  "type": "string"
                },
                "vulnerableRevision": {
                  "type": "string"
                },
                "repairedRevision": {
                  "type": "string"
                },
                "vulnerableRevisionWitnessSucceeded": {
                  "type": "boolean"
                },
                "repairedRevisionWitnessBlocked": {
                  "type": "boolean"
                },
                "legitimateBehaviorPassed": {
                  "type": "boolean"
                },
                "architectureControlChanged": {
                  "type": "boolean"
                },
                "commands": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "notes": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "artifacts": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "recordedAt",
                "recordedBy",
                "vulnerableRevisionWitnessSucceeded",
                "repairedRevisionWitnessBlocked",
                "legitimateBehaviorPassed",
                "architectureControlChanged",
                "commands",
                "notes",
                "artifacts"
              ],
              "additionalProperties": false
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "fingerprint",
          "title",
          "severity",
          "origin",
          "status",
          "stride",
          "cwe",
          "asset",
          "attackerCapability",
          "entryPoint",
          "trustBoundary",
          "precondition",
          "attackPath",
          "potentialImpact",
          "existingControls",
          "missingControls",
          "securityInvariant",
          "evidence",
          "confidence",
          "verificationHistory",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "untrustedInstructionsObserved": {
          "type": "boolean"
        },
        "analysisBoundaryHeld": {
          "type": "boolean"
        },
        "notes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["untrustedInstructionsObserved", "analysisBoundaryHeld", "notes"],
      "additionalProperties": false
    },
    "limitations": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    },
    "usage": {
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "number"
        },
        "outputTokens": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["summary", "surfaceChanged", "findings", "integrity", "limitations"],
  "additionalProperties": false
}

                      "commit": {
                        "type": "string"
                      },
                      "snapshot": {
                        "type": "string",
                        "enum": ["base", "head"]
                      },
                      "subjectId": {
                        "type": "string"
                      }
                    },
                    "required": ["file", "extractor"],
                    "additionalProperties": false

            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "entrypoint",
              "middleware",
              "auth-control",
              "authorization-control",
              "database",
              "data-model",
              "storage",
              "external-service",
              "secret",
              "dependency",
              "component"
            ]
          },
          "label": {
            "type": "string"
          },
          "trustZone": {
            "default": "unknown",

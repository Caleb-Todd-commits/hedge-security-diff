                  "type": "string",
                  "enum": [
                    "authentication",
                    "authorization",
                    "validation",
                    "rate-limit",
                    "size-limit",
                    "content-type",
                    "encryption",
                    "logging",
                    "ownership",
                    "other"
                  ]

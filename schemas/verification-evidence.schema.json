{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "recordedAt": {
      "type": "string"
    },
    "recordedBy": {
      "default": "unknown",
      "type": "string"
    },
    "vulnerableRevision": {
      "type": "string"
    },
    "repairedRevision": {
      "type": "string"
    },
    "vulnerableRevisionWitnessSucceeded": {
      "type": "boolean"
    },
    "repairedRevisionWitnessBlocked": {
      "type": "boolean"
    },
    "legitimateBehaviorPassed": {
      "type": "boolean"
    },
    "architectureControlChanged": {
      "type": "boolean"
    },
    "witnessDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "vulnerableOutcome": {
      "type": "string",
      "enum": ["reproduced", "blocked-by-control", "inconclusive"]
    },
    "repairedOutcome": {
      "type": "string",
      "enum": ["reproduced", "blocked-by-control", "inconclusive"]
    },
    "graphDeltaDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "architectureEvidence": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "endLine": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "snippet": {
            "type": "string"
          },
          "extractor": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "snapshot": {
            "type": "string",
            "enum": ["base", "head"]
          },
          "subjectId": {
            "type": "string"
          }
        },
        "required": ["file", "extractor"],
        "additionalProperties": false
      }
    },
    "commands": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "recordedAt",
    "recordedBy",
    "vulnerableRevisionWitnessSucceeded",
    "repairedRevisionWitnessBlocked",
    "legitimateBehaviorPassed",
    "architectureControlChanged",
    "architectureEvidence",
    "commands",
    "notes",
    "artifacts"
  ],
  "additionalProperties": false
}
